{
  "name": "@kyberbot/cli",
  "version": "1.9.0",
  "description": "KyberBot CLI — personal AI agent powered by Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kyberbot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
