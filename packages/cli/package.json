    "@sentry/node": "^10.43.0",
    "@whiskeysockets/baileys": "^6.7.21",
    "chalk": "^5.3.0",
    "chromadb": "^1.9.2",
    "chrono-node": "^2.7.0",
    "commander": "^12.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "grammy": "^1.30.0",
    "inquirer": "^12.0.0",
    "js-yaml": "^4.1.0",
    "libsql": "0.5.29",
    "openai": "^4.73.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
