# KyberBot Environment Variables
# Copy this to .env and fill in values

# ═══════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════

# OpenAI API key for embeddings (text-embedding-3-small).
# Also enables fast (~300ms) GPT-based reranking in `kyberbot search` via
# gpt-5.4-nano. Without this key, rerank falls back to Claude Haiku
# subprocess (~2s). Cost at typical personal use: ~$0.50-2/year for
# embeddings + ~$24-72/year for rerank. Override the rerank model in
# identity.yaml under `rerank.model`, or disable with KYBERBOT_RERANK_PROVIDER=claude.
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════
# OPTIONAL — Claude SDK Mode
# ═══════════════════════════════════════════════════

# Anthropic API key (enables SDK mode for faster brain operations)
# If not set, falls back to claude CLI subprocess (subscription mode)
# ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════
# OPTIONAL — Server
# ═══════════════════════════════════════════════════

# API authentication token (auto-generated during onboard, use `kyberbot token` to manage)
# KYBERBOT_API_TOKEN=kb_...

# ═══════════════════════════════════════════════════
# OPTIONAL — Services
# ═══════════════════════════════════════════════════

# ChromaDB URL (default: http://localhost:8001)
# Change if running ChromaDB on a different port
# CHROMA_URL=http://localhost:8001

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
