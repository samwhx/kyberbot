# KyberBot Environment Variables
# Copy this to .env and fill in values

# ═══════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════

# OpenAI API key for embeddings (text-embedding-3-small).
# Also enables fast (~300ms) GPT-based reranking in `kyberbot search` via
# gpt-5.4-nano. Without this key, rerank falls back to Claude Haiku
# subprocess (~2s). Cost at typical personal use: ~$0.50-2/year for
# embeddings + ~$24-72/year for rerank. Override the rerank model in
# identity.yaml under `rerank.model`, or disable with KYBERBOT_RERANK_PROVIDER=claude.
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════
# OPTIONAL — Claude SDK Mode
# ═══════════════════════════════════════════════════

# Anthropic API key (enables SDK mode for faster brain operations)
# If not set, falls back to claude CLI subprocess (subscription mode)
# ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════
# OPTIONAL — Server
# ═══════════════════════════════════════════════════

# API authentication token (auto-generated during onboard, use `kyberbot token` to manage)
# KYBERBOT_API_TOKEN=kb_...

# ═══════════════════════════════════════════════════
# OPTIONAL — Services
# ═══════════════════════════════════════════════════

# ChromaDB URL (default: http://localhost:8001)
# Change if running ChromaDB on a different port
# CHROMA_URL=http://localhost:8001

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# ═══════════════════════════════════════════════════
# OPTIONAL — Network bind overrides (advanced)
# ═══════════════════════════════════════════════════
#
# All HTTP servers bind 127.0.0.1 by default. Override only if you
# understand the LAN/internet exposure and have a firewall/Tailscale
# in front. Default is right for almost every personal deployment.
#
# KYBERBOT_BIND_HOST=127.0.0.1
# KYBERBOT_CHROMA_HOST=127.0.0.1

# ═══════════════════════════════════════════════════
# OPTIONAL — Rerank + embedding overrides
# ═══════════════════════════════════════════════════
#
# Force rerank provider (default: openai if OPENAI_API_KEY set, else claude).
# Setting to `claude` disables the OpenAI rerank path even with a key set.
# KYBERBOT_RERANK_PROVIDER=openai

# Embedding model (default: text-embedding-3-small)
# Switching invalidates the existing ChromaDB collection — re-index required.
# EMBEDDING_MODEL=text-embedding-3-small

# Warm Claude subprocess pool for messaging channels (Telegram, WhatsApp).
# Keeps a long-lived `claude --print` process per chat session so the next
# message in the same conversation skips the ~3-5s CLI startup. Trades
# ~200MB RAM per session for ~75% faster warm replies.
# Default off; set to 1 (or set claude.warm_pool: true in identity.yaml) to enable.
# KYBERBOT_WARM_POOL=1

# Self-learning Tier 2 — daily heartbeat that scans the last 24h of reply
# telemetry, runs pattern detectors, and drafts proposals into
# brain/proposals/<id>.md. Owner gets a Telegram ping when proposals exist.
# Approve/reject from chat ("approve <id>") or CLI (kyberbot proposals approve).
# Default off; set to 1 (or self_learning.enabled: true in identity.yaml) to enable.
# KYBERBOT_SELF_LEARNING=1

# ═══════════════════════════════════════════════════
# OPTIONAL — Observability
# ═══════════════════════════════════════════════════
#
# Telemetry dashboard auto-starts on port 4545 in fleet mode.
# Set =1 to disable. Override port if 4545 conflicts.
# KYBERBOT_NO_TELEMETRY=
# KYBERBOT_TELEMETRY_PORT=4545

# Sentry error reporting (off by default; set DSN to enable)
# SENTRY_DSN=
